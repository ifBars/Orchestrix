{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orchestrix",
  "version": "0.1.0",
  "identifier": "com.ghost.orchestrix",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Orchestrix",
        "width": 1220,
        "height": 820,
        "minWidth": 980,
        "minHeight": 660,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyNzRBM0FCNEVBQTA1QTcKUldTbkJhcE9xNk4wd2g4T0Y2aXRXSjhnWThYMHErWWRDbXFXRTJ0YWhCSnF4UnFQblRKbU9wRSsK",
      "endpoints": [
        "https://github.com/ifBars/Orchestrix/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
